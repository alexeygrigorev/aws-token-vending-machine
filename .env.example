# Copy to .env and fill in. Never commit the real .env.
# Only AWS_EXPERIMENTS_* keys are read by the CLI.

# AWS Organizations management ("main") account
AWS_EXPERIMENTS_MANAGEMENT_ACCOUNT_ID=123456789012
AWS_EXPERIMENTS_MANAGEMENT_ACCOUNT_EMAIL=aws@example.com
AWS_EXPERIMENTS_ORGANIZATION_ID=o-xxxxxxxxxx
AWS_EXPERIMENTS_ORGANIZATION_ROOT_ID=r-xxxx
AWS_EXPERIMENTS_OU_ID=ou-xxxx-xxxxxxxx

# Sandbox / experiments member account
AWS_EXPERIMENTS_ACCOUNT_ID=123456789013
AWS_EXPERIMENTS_ACCOUNT_EMAIL=aws+experiments@example.com
AWS_EXPERIMENTS_ACCOUNT_NAME=experiments
AWS_EXPERIMENTS_OU_NAME=Experiments
AWS_EXPERIMENTS_ADMIN_USER=experiments-admin
AWS_EXPERIMENTS_ACCESS_ROLE_NAME=OrganizationAccountAccessRole
AWS_EXPERIMENTS_MAX_SESSION_DURATION=7200

# Optional defaults for `creds`
AWS_EXPERIMENTS_REGION=eu-west-1
